source "https://rubygems.org"

# Define la versión del motor de Jekyll y el tema Chirpy
gem "jekyll", "~> 4.3.3"
gem "jekyll-theme-chirpy", "~> 7.0.1"

# Plugins requeridos por Chirpy para automatizar la navegación y SEO
group :jekyll_plugins do
  gem "jekyll-changelog"
  gem "jekyll-paginate"
  gem "jekyll-redirect-from"
  gem "jekyll-reading-time"
  gem "jekyll-sitemap"
  gem "jekyll-include-cache"
end